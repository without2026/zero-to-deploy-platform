{
  "type": "object",
  "properties": {
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file":        { "type": "string" },
          "line_start":  { "type": "integer" },
          "line_end":    { "type": "integer" },
          "severity":    { "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] },
          "category":    { "enum": ["security", "logic", "coverage", "style"] },
          "description": { "type": "string" },
          "evidence":    { "type": "string" },
          "confidence":  { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": [
          "file", "line_start", "severity", "category",
          "description", "evidence", "confidence"
        ],
        "additionalProperties": false
      }
    },
    "verdict": { "enum": ["pass", "warn", "block"] },
    "summary": { "type": "string" },
    "missing_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file":              { "type": "string" },
          "description":       { "type": "string" },
          "suggested_spec_id": { "type": "string" }
        },
        "required": ["file", "description"],
        "additionalProperties": false
      }
    }
  },
  "required": ["issues", "verdict"],
  "additionalProperties": false
}
